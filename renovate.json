{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Europe/Paris",
  "automerge": false,
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dashboard",

  "regexManagers": [
    {
      "fileMatch": [".*\\.gradle\\.kts"],
      "matchStrings": [
        "image\\s*=\\s*\"(?<depName>[^:@]+:[^@]+)@(?<currentValue>sha256:[a-f0-9]+)\""
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],

  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major-update"]
    },
    {
      "matchPackagePrefixes": ["org.jetbrains.kotlin"],
      "groupName": "Kotlin"
    },
    {
      "matchPackagePrefixes": ["io.javaoperatorsdk"],
      "groupName": "Java Operator SDK"
    },
    {
      "matchPackagePrefixes": ["io.fabric8"],
      "groupName": "Fabric8"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": ["gradle-wrapper"],
      "groupName": "Gradle Wrapper"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["eclipse-temurin"],
      "groupName": "JRE Base Image"
    },
    {
      "matchPackageNames": ["softprops/action-gh-release"],
      "matchManagers": ["github-actions"],
      "pinDigests": false
    }
  ]
}